# Providers. Defaults are mocks: the app runs with zero API keys and zero internet.
LLM_PROVIDER=mock            # mock | anthropic | gemini
SEARCH_PROVIDER=mock         # mock | tavily | exa
ANTHROPIC_API_KEY=
GEMINI_API_KEY=              # for LLM_PROVIDER=gemini (Google AI Studio)
# GEMINI_MODEL=gemini-2.0-flash
TAVILY_API_KEY=
EXA_API_KEY=                 # for SEARCH_PROVIDER=exa (semantic web search, free tier)

# Optional overrides
# DATABASE_URL=sqlite:////absolute/path/to/roadmap.sqlite3
# AUTO_SEED=1                # seed demo data on first start (default on)
# PORT=5000
 